html,
body{

margin:0;
width:100%;
height:100%;

background:#d9d9d9;

overflow:hidden;

display:flex;
justify-content:center;
align-items:center;

font-family:Arial,Helvetica,sans-serif;

}

#container{

display:flex;
flex-direction:column;
align-items:center;

}

#god{

width:240px;

user-select:none;
pointer-events:none;

transition:opacity 5s, transform .12s;

}

#god.talking{

transform:scale(1.02);

}

button{

margin-top:35px;

padding:14px 30px;

background:#111;

color:white;

border:none;

border-radius:8px;

font-size:16px;

cursor:pointer;

transition:.2s;

}

button:hover{

transform:scale(1.04);

}

button:disabled{

opacity:.5;

cursor:default;

}

.fade{

opacity:0;

}
